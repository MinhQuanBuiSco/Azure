# Home tenant (setup.sh writes these)
AZURE_HOME_TENANT_ID=your-tenant-id
AZURE_API_CLIENT_ID=your-api-client-id

# Comma-separated list of allowed tenant IDs (defaults to HOME_TENANT_ID)
ALLOWED_TENANT_IDS=your-tenant-id

# Set to "true" to allow any Azure AD tenant (skip allow-list)
# ALLOW_ANY_TENANT=false
