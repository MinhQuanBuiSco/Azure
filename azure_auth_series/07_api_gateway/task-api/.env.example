# Task API — extended from Blog 6 with gateway trust mode
AZURE_HOME_TENANT_ID=your-tenant-id
AZURE_API_CLIENT_ID=your-api-client-id
AZURE_API_CLIENT_SECRET=your-api-client-secret
ALLOWED_TENANT_IDS=your-tenant-id
# ALLOW_ANY_TENANT=false

# Downstream services (direct URLs — not through APIM)
AZURE_NOTIFICATION_CLIENT_ID=your-notification-client-id
NOTIFICATION_URL=http://localhost:8001
AZURE_AUDIT_CLIENT_ID=your-audit-client-id
AUDIT_URL=http://localhost:8002

# Blog 7: Gateway trust mode (set to true when behind APIM)
TRUST_GATEWAY=false
